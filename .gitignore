# ======= General =======
# Ignore files generated by editors, OS, or build tools

# Python virtual environments
.venv/
venv/
ENV/
env/
env.bak/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
pip-wheel-metadata/
*.egg
*.whl

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml
.hypothesis/

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Environment and secret files
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Logs and databases
*.log
*.sqlite3

# C extensions / compiled libs
*.so
*.dylib

# Misc
*.pot
*.mo
.cache/
